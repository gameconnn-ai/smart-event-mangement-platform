# MongoDB connection string
# Option 1: Local MongoDB (recommended for development)
MONGO_URI=mongodb://localhost:27017/smart_events

# Option 2: MongoDB Atlas (cloud) - replace with your own Atlas URI
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_events

# Session secret - use any random string you want
SESSION_SECRET=mySecretKey123

# Port the server runs on
PORT=3000
